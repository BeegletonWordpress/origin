{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "my-custom-block/handdrawn-header",
	"version": "0.1.0",
	"title": "Handdrawn Header",
	"category": "text",
	"icon": "heading",
	"description": "A header with a handdrawn SVG underline decoration.",
	"supports": {
		"html": false,
		"anchor": true,
		"align": ["wide", "full", "left", "center", "right"],
		"layout": {
			"allowEditing": true,
			"allowInheriting": true
		},
		"spacing": {
			"margin": true,
			"padding": true
		},
		"color": {
			"background": true,
			"text": true
		}
	},
	"attributes": {
		"backgroundColor": {
			"type": "string"
		},
		"style": {
			"type": "object"
		},
		"svgColor": {
			"type": "string"
		},
		"underlineSpacing": {
			"type": "number",
			"default": 2.5
		},
		"minWidth": {
			"type": "number",
			"default": 150
		},
		"underlineWidth": {
			"type": "number"
		},
		"underlineShape": {
			"type": "string",
			"default": "underline"
		},
	"ringSpacing": {
		"type": "number",
		"default": 50
	}
	},
	"textdomain": "my-custom-block",
	"editorScript": "file:./index.js",
	"style": "file:./style.css"
}
