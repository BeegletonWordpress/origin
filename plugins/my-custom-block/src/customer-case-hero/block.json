{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "create-block/customer-case-hero",
	"version": "0.1.0",
	"title": "Customer Case Hero",
	"category": "theme",
	"icon": "welcome-widgets-menus",
	"description": "A hero block for customer case study pages.",
	"supports": {
		"html": false,
		"align": ["full", "wide"],
		"spacing": {
			"margin": true,
			"padding": true
		},
		"color": {
			"background": true,
			"text": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true
		}
	},
	"attributes": {
		"tagline": {
			"type": "string",
			"source": "html",
			"selector": "p"
		},
		"title": {
			"type": "string",
			"source": "html",
			"selector": "h1",
			"default": "Customer Case Hero"
		},
		"subheader": {
			"type": "string",
			"source": "html",
			"selector": "h2"
		},
		"imageUrl": {
			"type": "string",
			"default": "https://beegleton-dev.local/wp-content/uploads/2026/03/Rectangle-4.png"
		},
		"imageAlt": {
			"type": "string",
			"default": "Customer Case Hero Image"
		},
		"imageId": {
			"type": "number"
		},
		"svgColor": {
			"type": "string"
		},
		"theme": {
			"type": "string",
			"default": "default"
		},
		"reverseLayout": {
			"type": "boolean",
			"default": false
		}
	},
	"textdomain": "my-custom-block",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css",
	"editorStyle": "file:./index.css",
	"viewScript": "file:./view.js"
}