{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "create-block/my-header-block",
	"version": "0.1.0",
	"title": "My Header Block",
	"category": "theme",
	"icon": "layout",
	"description": "Custom header recreated from Gutenberg design.",
	"supports": {
		"align": [ "full" ],
		"color": {
			"background": true,
			"text": false,
			"gradients": false
		},
		"spacing": {
			"padding": true,
			"margin": true
		},
		"position": {
			"sticky": true
		},
		"html": false
	},
	"attributes": {
		"align": {
			"type": "string",
			"default": "full"
		},
		"backgroundColor": {
			"type": "string",
			"default": "accent-1"
		},
		"style": {
			"type": "object",
			"default": {
				"spacing": {
					"padding": {
						"top": "var:preset|spacing|30",
						"bottom": "var:preset|spacing|30"
					}
				}
			}
		}
	},
	"textdomain": "my-custom-block",
	"editorScript": "file:./index.js",
	"style": [ "file:./index.css", "file:./style-index.css" ],
	"editorStyle": "file:./editor.css"
}
