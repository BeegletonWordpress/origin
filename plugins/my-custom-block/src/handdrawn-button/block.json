{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "create-block/my-handdrawn-button",
	"version": "0.1.0",
	"title": "My Handdrawn Button",
	"category": "theme",
	"icon": "button",
	"description": "A custom button with an irregular, hand-drawn look.",
	"supports": {
		"color": {
			"background": true,
			"text": true,
			"gradients": true
		},
		"spacing": {
			"padding": true,
			"margin": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true
		},
		"align": [ "left", "center", "right" ],
		"html": false
	},
	"attributes": {
		"backgroundColor": {
			"type": "string"
		},
		"textColor": {
			"type": "string"
		},
		"style": {
			"type": "object",
			"default": {
				"color": {
					"background": "var(--wp--preset--color--primary)",
					"text": "#fff"
				},
				"spacing": {
					"padding": {
						"top": "13px",
						"right": "35px",
						"bottom": "13px",
						"left": "35px"
					}
				},
				"typography": {
					"fontSize": "1rem",
					"lineHeight": "1.5"
				}
			}
		},
		"text": {
			"type": "string",
			"default": "Button Text"
		},
		"url": {
			"type": "string"
		},
		"linkTarget": {
			"type": "string"
		},
		"rel": {
			"type": "string"
		},
		"isSubmit": {
			"type": "boolean",
			"default": false
		},
		"hoverBackgroundColor": {
			"type": "string"
		},
		"isSecondary": {
			"type": "boolean",
			"default": false
		}
	},
	"textdomain": "my-custom-block",
	"editorScript": "file:./index.js",
	"style": [ "file:./index.css", "file:./style-index.css" ],
	"editorStyle": "file:./editor.css"
}
