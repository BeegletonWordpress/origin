{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "my-custom-block/animation-arrow",
	"version": "0.1.0",
	"title": "Animated Arrow",
	"category": "layout",
	"icon": "arrow-right-alt",
	"description": "An animated arrow with lottiefiles animation.",
	"supports": {
		"html": false,
		"anchor": true,
		"align": ["wide", "full"],
		"layout": {
			"allowEditing": true,
			"allowInheriting": true
		},
		"spacing": {
			"margin": true,
			"padding": true
		},
		"color": {
			"background": true,
			"text": true
		}
	},
	"attributes": {
		"backgroundColor": {
			"type": "string"
		},
		"style": {
			"type": "object"
		}
	},
	"textdomain": "my-custom-block",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./editor.css",
	"style": "file:./style.css",
	"viewScript": "file:./view.js"
}
