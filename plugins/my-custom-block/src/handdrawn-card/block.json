{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "create-block/my-handdrawn-card",
	"version": "0.1.0",
	"title": "My Handdrawn Card",
	"category": "theme",
	"icon": "admin-page",
	"description": "A custom card with an irregular, hand-drawn look.",
	"example": {
		"attributes": {
			"text": "Get Started",
			"backgroundColor": "primary",
			"headerText": "Card Header",
			"subHeaderText": "Card Subheader",
			"bodyText": "This is the body of the card. You can add more text here to describe the content of the card."
		}
	},
	"supports": {
		"color": {
			"background": true,
			"text": true,
			"gradients": true
		},
		"spacing": {
			"padding": true,
			"margin": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true
		},
		"align": ["left", "center", "right"],
		"html": false
	},
	"attributes": {
		"headerText": {
			"type": "string",
			"default": "Card Header"
		},
		"subHeaderText": {
			"type": "string",
			"default": "Card Subheader"
		},
		"bodyText": {
			"type": "string",
			"default": "This is the body of the card. You can add more text here to describe the content of the card."
		}
	},
	"textdomain": "my-custom-block",
	"editorScript": "file:./index.js",
	"style": ["file:./index.css", "file:./style-index.css"],
	"editorStyle": "file:./editor.css"
}
