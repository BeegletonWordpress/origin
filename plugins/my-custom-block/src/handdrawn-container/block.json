{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "my-custom-block/handdrawn-container",
	"version": "0.1.0",
	"title": "Handdrawn Container",
	"category": "layout",
	"icon": "layout",
	"description": "A container with a handdrawn SVG background decoration.",
	"supports": {
		"html": false,
		"anchor": true,
		"align": [ "wide", "full" ],
		"layout": {
			"allowEditing": true,
			"allowInheriting": true
		},
		"spacing": {
			"margin": true,
			"padding": true
		},
		"color": {
			"background": true,
			"text": true
		}
	},
	"attributes": {
		"backgroundColor": {
			"type": "string"
		},
		"style": {
			"type": "object"
		},
		"svgColor": {
			"type": "string"
		}
	},
	"textdomain": "my-custom-block",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./editor.css",
	"style": "file:./style.css"
}
