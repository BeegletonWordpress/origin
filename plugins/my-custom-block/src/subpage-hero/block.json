{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "create-block/subpage-hero",
	"version": "0.1.0",
	"title": "Subpage Hero",
	"category": "theme",
	"icon": "welcome-widgets-menus",
	"description": "A hero block specifically for subpages.",
	"supports": {
		"html": false,
		"align": [ "full", "wide" ],
		"spacing": {
			"margin": true,
			"padding": true
		},
		"color": {
			"background": true,
			"text": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true
		}
	},
	"attributes": {
		"title": {
			"type": "string",
			"source": "html",
			"selector": "h1",
			"default": "Subpage Hero"
		},
		"content": {
			"type": "string",
			"source": "html",
			"selector": ".subpage-hero__content",
			"default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit..."
		},
		"imageUrl": {
			"type": "string",
			"default": "https://beegleton-dev.local/wp-content/uploads/2026/03/Rectangle-4.png"
		},
		"imageAlt": {
			"type": "string",
			"default": "Subpage Hero Image"
		},
		"imageId": {
			"type": "number"
		},
		"svgColor": {
			"type": "string"
		},
		"theme": {
			"type": "string",
			"default": "default"
		}
	},
	"textdomain": "my-custom-block",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css",
	"editorStyle": "file:./index.css"
}
