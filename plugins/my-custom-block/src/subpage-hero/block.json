{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "create-block/subpage-hero",
	"version": "0.1.0",
	"title": "Subpage Hero",
	"category": "theme",
	"icon": "welcome-widgets-menus",
	"description": "A hero block specifically for subpages.",
	"supports": {
		"html": false,
		"align": [ "full", "wide" ],
		"spacing": {
			"margin": true,
			"padding": true
		},
		"color": {
			"background": true,
			"text": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true
		}
	},
	"attributes": {},
	"textdomain": "my-custom-block",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css",
	"editorStyle": "file:./index.css"
}
