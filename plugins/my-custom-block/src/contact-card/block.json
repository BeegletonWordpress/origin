{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "create-block/contact-card",
	"version": "0.1.0",
	"title": "Contact Card",
	"category": "theme",
	"icon": "index-card",
	"description": "A contact card block with hand-drawn shapes and hover effects.",
	"attributes": {
		"cardShape": {
			"type": "string",
			"default": "shape1"
		},
		"svgColor": {
			"type": "string",
			"default": "#3B3632"
		},
		"imageNormal": {
			"type": "object"
		},
		"imageHover": {
			"type": "object"
		},
		"staffMemberId": {
			"type": "number"
		},
		"name": {
			"type": "string"
		},
		"role": {
			"type": "string"
		},
		"email": {
			"type": "string"
		},
		"phone": {
			"type": "string"
		}
	},
	"supports": {
		"html": false,
		"align": true,
		"spacing": {
			"margin": true,
			"padding": true
		},
		"color": {
			"background": true,
			"text": true
		}
	},
	"textdomain": "my-custom-block",
	"editorScript": "file:./index.js",
	"style": "file:./style.css"
}
