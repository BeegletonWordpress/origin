{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "create-block/subpage-content",
	"version": "0.1.0",
	"title": "Subpage Content",
	"category": "theme",
	"icon": "layout",
	"description": "Page content area for subpages. Uses WordPress theme colors.",
	"supports": {
		"html": false,
		"align": ["full", "wide"],
		"spacing": {
			"margin": true,
			"padding": true
		}
	},
	"attributes": {
		"alignment": {
			"type": "string",
			"default": "full"
		}
	},
	"textdomain": "my-custom-block",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css",
	"editorStyle": "file:./index.css"
}
