{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "create-block/hero",
	"version": "0.1.0",
	"title": "Hero Block",
	"category": "theme",
	"icon": "welcome-widgets-menus",
	"description": "A hero section for the landing page with text on the left and a 3-image grid on the right.",
	"supports": {
		"html": false,
		"align": ["full", "wide"],
		"spacing": {
			"margin": true,
			"padding": true
		}
	},
	"attributes": {
		"svgColor": {
			"type": "string",
			"default": "#EDB239"
		}
	},
	"textdomain": "my-custom-block",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css",
	"editorStyle": "file:./index.css",
	"viewScript": "file:./view.js"
}
