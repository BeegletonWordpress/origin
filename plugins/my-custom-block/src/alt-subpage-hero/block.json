{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "create-block/alt-subpage-hero",
	"version": "0.1.0",
	"title": "Alt Subpage Hero",
	"category": "theme",
	"icon": "welcome-widgets-menus",
	"description": "A hero block with optional right column for centered header layout.",
	"supports": {
		"html": false,
		"align": ["full", "wide"],
		"spacing": {
			"margin": true,
			"padding": true
		},
		"color": {
			"background": true,
			"text": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true
		}
	},
	"attributes": {
		"tagline": {
			"type": "string",
			"default": ""
		},
		"title": {
			"type": "string",
			"default": "Hero Title"
		},
		"svgColor": {
			"type": "string"
		},
		"theme": {
			"type": "string",
			"default": "default"
		},
		"reverseLayout": {
			"type": "boolean",
			"default": false
		},
		"showRightColumn": {
			"type": "boolean",
			"default": true
		}
	},
	"textdomain": "my-custom-block",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css",
	"editorStyle": "file:./index.css",
	"viewScript": "file:./view.js"
}
